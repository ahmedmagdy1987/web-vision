# Web Vision — environment contract (TEMPLATE — placeholders only)
# Copy this file to .env.local and fill in the real values:
#     cp .env.example .env.local
# .env.local is gitignored and must NEVER be committed. Only NEXT_PUBLIC_*
# values are exposed to the browser bundle.

# --- Public Supabase config (safe for the browser bundle) -------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key

# --- Data backend selection -------------------------------------------------
# "supabase" (default when the public config above is present) or "local" (the
# in-browser localStorage demo backend). Set to "local" to force demo mode even
# when Supabase is configured (e.g. for the Playwright demo suite).
NEXT_PUBLIC_DATA_BACKEND=supabase

# --- Site URL (used for auth email redirect / callback) ---------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only secret (NEVER prefix with NEXT_PUBLIC_, never commit) -------
# The service-role key bypasses RLS and must remain server-only. Do NOT give it
# a NEXT_PUBLIC_ prefix — that would leak it into the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-secret-key

# --- Image generation provider ----------------------------------------------
# Selects the mockup image provider. "mock" (default) renders local placeholder
# images and makes NO external calls. "openai" uses GPT Image 2 via the
# server-only /api/generate-image route. Selection is explicit — it never
# silently falls back to mock when set to "openai".
IMAGE_GENERATION_PROVIDER=mock
# Non-secret browser mirror of the above, so the client instantiates the right
# adapter (the actual provider call always happens server-side).
NEXT_PUBLIC_IMAGE_GENERATION_PROVIDER=mock

# --- OpenAI (server-only — NEVER prefix with NEXT_PUBLIC_, never commit) -----
# Required only when IMAGE_GENERATION_PROVIDER=openai. The key stays on the
# server (the /api/generate-image route) and is never sent to the browser.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=webp
# Maximum input reference images per request (cost / size control).
OPENAI_IMAGE_REFERENCE_LIMIT=6
